    "height-md":  { "value": "40px" },
    "height-lg":  { "value": "48px" },
    "px-sm":      { "value": "{space.4}" },
    "px-md":      { "value": "{space.6}" },
    "px-lg":      { "value": "{space.7}" },
    "radius":     { "value": "{radius.sm}" },
    "font":       { "value": "{font.mono}" },
    "weight":     { "value": "{weight.bold}" },
    "tracking":   { "value": "{tracking.wider}" },
    "transition": { "value": "{duration.normal} {ease.out}" },

    "primary-bg":       { "value": "{color.brand.primary}" },
