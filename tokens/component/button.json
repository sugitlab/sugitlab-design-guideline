    "secondary-border":   { "value": "{color.brand.secondary}" },

    "ghost-bg":       { "value": "transparent" },
    "ghost-bg-hover": { "value": "{color.bg.subtle}" },
    "ghost-bg-active":{ "value": "{color.bg.muted}" },
    "ghost-color":    { "value": "{color.text.primary}" },
    "ghost-border":   { "value": "transparent" },

    "disabled-bg":     { "value": "{color.bg.muted}" },
    "disabled-color":  { "value": "{color.text.disabled}" },
    "disabled-border": { "value": "{color.bg.muted}" }
